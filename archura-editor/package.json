{
  "name": "archura-editor",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "sh ../scripts/dev-up.sh",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build:app": "vite build",
    "build:components": "node scripts/build-components.mjs",
    "build": "npm run build:app && npm run build:components",
    "deploy": "npm run build && wrangler deploy",
    "practice": "node toy-client/server.mjs",
    "deploy:practice": "wrangler deploy --config toy-client/wrangler.jsonc",
    "verify:all": "node scripts/verify-all.mjs"
  },
  "dependencies": {
    "grapesjs": "^0.23.2",
    "lit": "^3.2.0"
  },
  "devDependencies": {
    "esbuild": "^0.28.1",
    "playwright": "^1.60.0",
    "typescript": "^5.0.0",
    "vite": "^6.0.0",
    "wrangler": "^4.110.0"
  }
}
