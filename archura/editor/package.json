{
  "name": "grapesjs-web-builder-example-app",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "svelte-kit sync && vite dev",
    "build": "svelte-kit sync && vite build",
    "preview": "vite preview",
    "test": "npm run test:lit",
    "test:contract": "node --test test/hero-attribute-contract.test.js",
    "test:lit": "wtr --config web-test-runner.config.mjs",
    "test:all": "npm run test:contract && npm run test:lit"
  },
  "devDependencies": {
    "@open-wc/testing": "^4.0.0",
    "@sveltejs/adapter-auto": "^6.0.0",
    "@sveltejs/kit": "^2.0.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@web/dev-server-esbuild": "^1.0.4",
    "@web/test-runner": "^0.20.0",
    "@web/test-runner-playwright": "^0.11.0",
    "playwright": "^1.52.0",
    "svelte": "^5.0.0",
    "typescript": "^5.0.0",
    "vite": "^6.0.0"
  },
  "dependencies": {
    "grapesjs": "^0.22.5",
    "lit": "^3.2.0"
  }
}
