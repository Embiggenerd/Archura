POSTGRES_IMAGE=postgres:17-alpine
CADDY_IMAGE=caddy:2-alpine
ARCHURA_ENV=staging
CORE_HOSTNAME=staging-core.archura.ai

# Use URL-safe random values so DATABASE_URL does not require extra escaping.
POSTGRES_DB=archura_staging
POSTGRES_USER=archura
POSTGRES_PASSWORD=replace-with-url-safe-random-password
DATABASE_URL=postgres://archura:replace-with-url-safe-random-password@postgres:5432/archura_staging?sslmode=disable

PLATFORM_ADMIN_KEY=adm_test_replace-with-generated-key
CORE_SERVICE_KEY=svc_test_replace-with-generated-key
# Machine credential for Worker cron/serving calls (release, entitlement)
CORE_INTERNAL_KEY=int_test_replace-with-generated-key
CONFIRM_URL_BASE=https://archura.ai/confirm
CLOUDFLARE_EMAIL_ACCOUNT_ID=replace-with-cloudflare-account-id
CLOUDFLARE_EMAIL_API_TOKEN=replace-with-email-service-token
EMAIL_FROM=hello@archura.ai

# Staging and production default this off; enabling it is an explicit choice.
# Platform-owner account sessions are still required when it is on.
ADMIN_API_ENABLED=true

# Kill switch for all core rate limits (see PLAN_RATE_LIMIT_KILL_SWITCH.md;
# no effect until that lands). Limits only enforce when ARCHURA_ENV=prod, so
# staging never needs this — it exists for testing against a live prod, and
# the server logs a WARN at boot while it is set there. Uncomment to disable.
# DISABLE_RATE_LIMITS=true

# The platform owner. `adminctl bootstrap` (and `grant-staff` with no argument)
# grants this account the platform_owner role. The account must exist (signed up)
# first. Locally, dev-up.sh reads this from the sourced .env and grants it.
PLATFORM_OWNER_EMAIL=owner@archura.ai

# Staging accepts only Stripe test mode. These four values are optional as a
# group until billing is enabled.
# STRIPE_SECRET_KEY=sk_test_replace-with-stripe-test-secret
# STRIPE_WEBHOOK_SECRET=whsec_replace-with-webhook-signing-secret
# STRIPE_BASIC_PRICE_ID=price_replace-with-recurring-basic-price
# BILLING_PUBLIC_ORIGIN=https://archura.ai

# Optional: set these only when enabling backup-postgres.sh and its timer.
# BACKUP_DIR=/var/backups/archura-core
# BACKUP_RETENTION_DAYS=7
# OFFSITE_BACKUP_DEST=hetzner-object:archura-core/staging-postgres
