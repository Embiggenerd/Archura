POSTGRES_IMAGE=postgres:17-alpine
CADDY_IMAGE=caddy:2-alpine
CORE_HOSTNAME=core.example.com

# Use URL-safe random values so DATABASE_URL does not require extra escaping.
POSTGRES_DB=archura
POSTGRES_USER=archura
POSTGRES_PASSWORD=replace-with-url-safe-random-password
DATABASE_URL=postgres://archura:replace-with-url-safe-random-password@postgres:5432/archura?sslmode=disable

PLATFORM_ADMIN_KEY=adm_live_replace-with-generated-key
CORE_SERVICE_KEY=svc_live_replace-with-generated-key
# Machine credential for Worker cron/serving calls (release, entitlement)
CORE_INTERNAL_KEY=int_live_replace-with-generated-key
CONFIRM_URL_BASE=https://archura.ai/confirm
CLOUDFLARE_EMAIL_ACCOUNT_ID=replace-with-cloudflare-account-id
CLOUDFLARE_EMAIL_API_TOKEN=replace-with-email-service-token
EMAIL_FROM=hello@archura.ai

# Stripe test mode for the initial $5/month organization plan. These four
# values are optional as a group until billing is enabled.
# STRIPE_SECRET_KEY=sk_test_replace-with-stripe-test-secret
# STRIPE_WEBHOOK_SECRET=whsec_replace-with-webhook-signing-secret
# STRIPE_BASIC_PRICE_ID=price_replace-with-recurring-basic-price
# BILLING_PUBLIC_ORIGIN=https://archura.ai

# Optional: set these only when enabling backup-postgres.sh and its timer.
# BACKUP_DIR=/var/backups/archura-core
# BACKUP_RETENTION_DAYS=7
# OFFSITE_BACKUP_DEST=hetzner-object:archura-core/postgres
