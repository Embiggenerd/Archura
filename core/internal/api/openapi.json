{
  "openapi": "3.1.0",
  "info": {
    "title": "Archura Core API",
    "version": "0.1.0",
    "description": "Identity, ownership, and component-session API for Archura. Production /v1 requests require the Worker service credential plus any endpoint-specific bearer credential."
  },
  "servers": [
    { "url": "/", "description": "Current core server" }
  ],
  "tags": [
    { "name": "Operations", "description": "Process and dependency health" },
    { "name": "Organizations", "description": "Business and billing boundaries shared by account members" },
    { "name": "Clients", "description": "Legacy platform-admin organization onboarding" },
    { "name": "Components", "description": "Organization-owned payment component configuration" },
    { "name": "Sessions", "description": "Component and account sessions" },
    { "name": "Accounts", "description": "Email-confirmed accounts and site ownership" },
    { "name": "Confirmations", "description": "Single-use email confirmation links" },
    { "name": "Development", "description": "Development-only testing helpers" }
  ],
  "components": {
    "securitySchemes": {
      "ServiceAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-Archura-Service-Authorization",
        "description": "Worker credential including the Bearer prefix, for example `Bearer svc_live_...`. Required in production and optional in direct local development."
      },
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "adm_..., sk_..., or sess_...",
        "description": "Platform-admin key, organization secret key, or account session token, according to the operation."
      }
    },
    "schemas": {
      "Error": {
        "type": "object",
        "required": ["error"],
        "properties": {
          "error": {
            "type": "object",
            "required": ["code", "message"],
            "properties": {
              "code": { "type": "string", "example": "invalid_api_key" },
              "message": { "type": "string", "example": "The organization API key is invalid." },
              "request_id": { "type": "string", "example": "core/abc123-000001" }
            }
          }
        }
      },
      "Health": {
        "type": "object",
        "required": ["status", "version", "commit", "build_time"],
        "properties": {
          "status": { "type": "string", "const": "ok" },
          "version": { "type": "string" },
          "commit": { "type": "string" },
          "build_time": { "type": "string" }
        }
      },
      "Readiness": {
        "type": "object",
        "required": ["status"],
        "properties": {
          "status": { "type": "string", "enum": ["ready", "no_database", "db_unreachable"] }
        }
      },
      "CreateClientRequest": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "slug", "allowed_origins"],
        "properties": {
          "name": { "type": "string", "minLength": 1, "example": "Mike's Bakery" },
          "slug": { "type": "string", "pattern": "^[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?$", "example": "mikes-bakery" },
          "allowed_origins": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "format": "uri" },
            "example": ["https://mikesbakery.example"]
          },
          "edge_claim_token": {
            "type": "string",
            "maxLength": 128,
            "writeOnly": true,
            "description": "Optional opaque edge namespace credential, limited to 128 UTF-8 bytes. Stored for the organization binding and never returned."
          }
        }
      },
      "ClientCreated": {
        "type": "object",
        "required": ["id", "name", "slug", "publishable_key", "secret_key", "created_at"],
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "name": { "type": "string" },
          "slug": { "type": "string" },
          "publishable_key": { "type": "string", "pattern": "^pk_(?:test|live)_", "example": "pk_test_..." },
          "secret_key": { "type": "string", "pattern": "^sk_(?:test|live)_", "example": "sk_test_...", "description": "Returned once. Never place this key in a browser or artifact." },
          "created_at": { "type": "string", "format": "date-time" }
        }
      },
      "ComponentConfiguration": {
        "type": "object",
        "additionalProperties": false,
        "required": ["mode", "stripe_price_id", "success_url", "cancel_url", "allowed_origins"],
        "properties": {
          "mode": { "type": "string", "enum": ["payment", "subscription"] },
          "stripe_price_id": { "type": "string", "pattern": "^price_", "example": "price_123" },
          "success_url": { "type": "string", "format": "uri", "example": "https://mikesbakery.example/order/success" },
          "cancel_url": { "type": "string", "format": "uri", "example": "https://mikesbakery.example/order/cancel" },
          "allowed_origins": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "format": "uri" },
            "example": ["https://mikesbakery.example"]
          },
          "status": { "type": "string", "enum": ["active", "inactive"], "default": "active" }
        }
      },
      "Component": {
        "allOf": [
          { "$ref": "#/components/schemas/ComponentConfiguration" },
          {
            "type": "object",
            "required": ["id", "status", "created_at", "updated_at"],
            "properties": {
              "id": { "type": "string", "pattern": "^cmp_(?:test|live)_", "example": "cmp_test_..." },
              "created_at": { "type": "string", "format": "date-time" },
              "updated_at": { "type": "string", "format": "date-time" }
            }
          }
        ]
      },
      "CreateComponentSessionRequest": {
        "type": "object",
        "additionalProperties": false,
        "required": ["component_id", "origin"],
        "properties": {
          "component_id": { "type": "string", "pattern": "^cmp_(?:test|live)_", "example": "cmp_test_..." },
          "external_user_id": { "type": "string", "description": "Optional organization-owned user reference. Never written to operational or audit logs." },
          "origin": { "type": "string", "format": "uri", "example": "https://mikesbakery.example" }
        }
      },
      "ComponentSessionCreated": {
        "type": "object",
        "required": ["access_token", "token_type", "expires_in", "expires_at"],
        "properties": {
          "access_token": { "type": "string", "pattern": "^ct_(?:test|live)_", "example": "ct_test_...", "description": "Short-lived browser bearer token. Returned once and stored only as a hash." },
          "token_type": { "type": "string", "const": "Bearer" },
          "expires_in": { "type": "integer", "const": 600 },
          "expires_at": { "type": "string", "format": "date-time" }
        }
      },
      "CreateConfirmationRequest": {
        "type": "object",
        "additionalProperties": false,
        "required": ["email"],
        "properties": {
          "email": { "type": "string", "format": "email", "example": "owner@example.com" },
          "subdomain": { "type": "string", "pattern": "^[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?$", "example": "mikes-bakery" }
        }
      },
      "ConfirmationCreated": {
        "type": "object",
        "required": ["id", "expires_at"],
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "expires_at": { "type": "string", "format": "date-time" },
          "confirm_url": { "type": "string", "format": "uri", "description": "Present only in development." }
        }
      },
      "VerifyConfirmationRequest": {
        "type": "object",
        "additionalProperties": false,
        "required": ["token"],
        "properties": {
          "token": { "type": "string", "pattern": "^cfm_(?:test|live)_", "example": "cfm_test_..." }
        }
      },
      "Account": {
        "type": "object",
        "required": ["id", "email"],
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "email": { "type": "string", "format": "email" },
          "email_verified_at": { "type": ["string", "null"], "format": "date-time" }
        }
      },
      "AccountSession": {
        "type": "object",
        "required": ["token", "expires_at"],
        "properties": {
          "token": { "type": "string", "pattern": "^sess_(?:test|live)_", "description": "Returned once and stored only as a hash." },
          "expires_at": { "type": "string", "format": "date-time" }
        }
      },
      "Organization": {
        "type": "object",
        "required": ["id", "name", "slug", "role", "is_default", "publishable_key", "sites", "created_at"],
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "name": { "type": "string" },
          "slug": { "type": "string" },
          "role": { "type": "string", "enum": ["owner", "member"] },
          "is_default": { "type": "boolean" },
          "publishable_key": { "type": "string", "pattern": "^pk_(?:test|live)_" },
          "sites": { "type": "array", "items": { "type": "string" } },
          "created_at": { "type": "string", "format": "date-time" }
        }
      },
      "CreateOrganizationRequest": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "slug"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "slug": { "type": "string", "pattern": "^[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?$" },
          "allowed_origins": { "type": "array", "items": { "type": "string", "format": "uri" } }
        }
      },
      "CreateInvitationRequest": {
        "type": "object",
        "additionalProperties": false,
        "required": ["email"],
        "properties": {
          "email": { "type": "string", "format": "email" }
        }
      },
      "Invitation": {
        "type": "object",
        "required": ["id", "organization", "email", "role", "invited_by", "status", "expires_at", "created_at"],
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "organization": {
            "type": "object",
            "required": ["id", "name"],
            "properties": {
              "id": { "type": "string", "format": "uuid" },
              "name": { "type": "string" }
            }
          },
          "email": { "type": "string", "format": "email" },
          "role": { "type": "string", "const": "member" },
          "invited_by": { "type": "string", "format": "email" },
          "status": { "type": "string", "enum": ["pending", "accepted", "declined", "revoked"] },
          "expires_at": { "type": "string", "format": "date-time" },
          "created_at": { "type": "string", "format": "date-time" }
        }
      },
      "ConfirmationVerified": {
        "type": "object",
        "required": ["account", "organization", "subdomain", "session"],
        "properties": {
          "account": { "$ref": "#/components/schemas/Account" },
          "organization": { "$ref": "#/components/schemas/Organization" },
          "subdomain": { "type": ["string", "null"] },
          "session": { "$ref": "#/components/schemas/AccountSession" }
        }
      },
      "SessionMe": {
        "type": "object",
        "required": ["account", "organizations", "invitations"],
        "properties": {
          "account": { "$ref": "#/components/schemas/Account" },
          "organizations": { "type": "array", "items": { "$ref": "#/components/schemas/Organization" } },
          "invitations": { "type": "array", "items": { "$ref": "#/components/schemas/Invitation" } }
        }
      },
      "BindSiteOwnershipRequest": {
        "type": "object",
        "additionalProperties": false,
        "required": ["subdomain"],
        "properties": {
          "subdomain": { "type": "string", "pattern": "^[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?$" },
          "organization_id": { "type": "string", "format": "uuid", "description": "Defaults to the account's default organization when omitted." }
        }
      },
      "SiteOwnership": {
        "type": "object",
        "required": ["subdomain", "organization_id"],
        "properties": {
          "subdomain": { "type": "string" },
          "organization_id": { "type": "string", "format": "uuid" }
        }
      },
      "DevConfirmations": {
        "type": "object",
        "required": ["confirmations", "invitations"],
        "properties": {
          "confirmations": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["email", "subdomain", "confirm_url", "created_at", "used", "expired"],
              "properties": {
                "email": { "type": "string", "format": "email" },
                "subdomain": { "type": ["string", "null"] },
                "confirm_url": { "type": "string", "format": "uri" },
                "created_at": { "type": "string", "format": "date-time" },
                "used": { "type": "boolean" },
                "expired": { "type": "boolean", "description": "True only for an unused confirmation whose TTL elapsed." }
              }
            }
          },
          "invitations": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["invitation_id", "organization_id", "organization_name", "email", "invited_by", "account_url", "created_at"],
              "properties": {
                "invitation_id": { "type": "string" },
                "organization_id": { "type": "string" },
                "organization_name": { "type": "string" },
                "email": { "type": "string", "format": "email" },
                "invited_by": { "type": "string", "format": "email" },
                "account_url": { "type": "string", "format": "uri" },
                "created_at": { "type": "string", "format": "date-time" }
              }
            }
          }
        }
      }
    },
    "responses": {
      "BadRequest": { "description": "Invalid request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
      "Unauthorized": { "description": "Missing or invalid service/admin/organization credential", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
      "Forbidden": { "description": "Authenticated but not allowed", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
      "NotFound": { "description": "Resource not found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
      "Conflict": { "description": "Resource conflict", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
      "RateLimited": { "description": "Rate limit exceeded", "headers": { "Retry-After": { "schema": { "type": "integer" } } }, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
      "BadGateway": { "description": "Upstream delivery failed", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
      "InternalError": { "description": "Internal error", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
      "Unavailable": { "description": "Database unavailable", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
    }
  },
  "paths": {
    "/healthz": {
      "get": {
        "tags": ["Operations"],
        "operationId": "getHealth",
        "summary": "Process liveness",
        "security": [],
        "responses": {
          "200": { "description": "Core process is running", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Health" } } } }
        }
      }
    },
    "/readyz": {
      "get": {
        "tags": ["Operations"],
        "operationId": "getReadiness",
        "summary": "Database readiness",
        "security": [],
        "responses": {
          "200": { "description": "Database is reachable", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Readiness" } } } },
          "503": { "description": "Database is absent or unreachable", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Readiness" } } } }
        }
      }
    },
    "/v1/clients": {
      "post": {
        "tags": ["Clients"],
        "operationId": "createClient",
        "summary": "Create an organization and issue API keys",
        "description": "Legacy platform-admin route. The returned organization secret is shown once.",
        "security": [{ "ServiceAuth": [], "BearerAuth": [] }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CreateClientRequest" } } } },
        "responses": {
          "201": { "description": "Organization created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ClientCreated" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "409": { "$ref": "#/components/responses/Conflict" },
          "429": { "$ref": "#/components/responses/RateLimited" },
          "500": { "$ref": "#/components/responses/InternalError" },
          "503": { "$ref": "#/components/responses/Unavailable" }
        }
      }
    },
    "/v1/components": {
      "post": {
        "tags": ["Components"],
        "operationId": "createComponent",
        "summary": "Create an organization-owned payment component",
        "description": "Requires the organization secret. Price and redirect configuration are stored server-side and later bound to component sessions.",
        "security": [{ "ServiceAuth": [], "BearerAuth": [] }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ComponentConfiguration" } } } },
        "responses": {
          "201": { "description": "Component created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Component" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "429": { "$ref": "#/components/responses/RateLimited" },
          "500": { "$ref": "#/components/responses/InternalError" },
          "503": { "$ref": "#/components/responses/Unavailable" }
        }
      }
    },
    "/v1/components/{componentID}": {
      "put": {
        "tags": ["Components"],
        "operationId": "updateComponent",
        "summary": "Update an organization-owned payment component",
        "security": [{ "ServiceAuth": [], "BearerAuth": [] }],
        "parameters": [
          { "name": "componentID", "in": "path", "required": true, "schema": { "type": "string", "pattern": "^cmp_(?:test|live)_" } }
        ],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ComponentConfiguration" } } } },
        "responses": {
          "200": { "description": "Component updated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Component" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "429": { "$ref": "#/components/responses/RateLimited" },
          "500": { "$ref": "#/components/responses/InternalError" },
          "503": { "$ref": "#/components/responses/Unavailable" }
        }
      }
    },
    "/v1/component-sessions": {
      "post": {
        "tags": ["Sessions"],
        "operationId": "createComponentSession",
        "summary": "Mint a short-lived component bearer token",
        "description": "Called by the organization backend after it authenticates its own user. The token is bound to the organization, component, checkout:create scope, checkout audience, origin, and ten-minute expiry.",
        "security": [{ "ServiceAuth": [], "BearerAuth": [] }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CreateComponentSessionRequest" } } } },
        "responses": {
          "201": { "description": "Component session created", "headers": { "Cache-Control": { "schema": { "type": "string", "example": "no-store" } } }, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ComponentSessionCreated" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "429": { "$ref": "#/components/responses/RateLimited" },
          "500": { "$ref": "#/components/responses/InternalError" },
          "503": { "$ref": "#/components/responses/Unavailable" }
        }
      }
    },
    "/v1/confirmations": {
      "post": {
        "tags": ["Confirmations"],
        "operationId": "createConfirmation",
        "summary": "Create a single-use email confirmation",
        "security": [{ "ServiceAuth": [] }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CreateConfirmationRequest" } } } },
        "responses": {
          "201": { "description": "Confirmation created", "headers": { "Cache-Control": { "schema": { "type": "string", "example": "no-store" } } }, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ConfirmationCreated" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "409": { "$ref": "#/components/responses/Conflict" },
          "429": { "$ref": "#/components/responses/RateLimited" },
          "500": { "$ref": "#/components/responses/InternalError" },
          "503": { "$ref": "#/components/responses/Unavailable" }
        }
      }
    },
    "/v1/confirmations/verify": {
      "post": {
        "tags": ["Confirmations"],
        "operationId": "verifyConfirmation",
        "summary": "Consume a confirmation and create an account session",
        "security": [{ "ServiceAuth": [] }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/VerifyConfirmationRequest" } } } },
        "responses": {
          "200": { "description": "Confirmation verified", "headers": { "Cache-Control": { "schema": { "type": "string", "example": "no-store" } } }, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ConfirmationVerified" } } } },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "409": { "$ref": "#/components/responses/Conflict" },
          "500": { "$ref": "#/components/responses/InternalError" },
          "503": { "$ref": "#/components/responses/Unavailable" }
        }
      }
    },
    "/v1/sessions/me": {
      "get": {
        "tags": ["Accounts", "Sessions"],
        "operationId": "getAccountSession",
        "summary": "Return the current account and its organizations",
        "security": [{ "ServiceAuth": [], "BearerAuth": [] }],
        "responses": {
          "200": { "description": "Current account session", "headers": { "Cache-Control": { "schema": { "type": "string", "example": "no-store" } } }, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SessionMe" } } } },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "500": { "$ref": "#/components/responses/InternalError" },
          "503": { "$ref": "#/components/responses/Unavailable" }
        }
      }
    },
    "/v1/organizations": {
      "post": {
        "tags": ["Organizations", "Accounts"],
        "operationId": "createOrganization",
        "summary": "Create another organization for the current account",
        "security": [{ "ServiceAuth": [], "BearerAuth": [] }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CreateOrganizationRequest" } } } },
        "responses": {
          "201": { "description": "Organization created; secret_key is returned once", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Organization" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "409": { "$ref": "#/components/responses/Conflict" },
          "500": { "$ref": "#/components/responses/InternalError" },
          "503": { "$ref": "#/components/responses/Unavailable" }
        }
      }
    },
    "/v1/organizations/{organizationID}/invitations": {
      "post": {
        "tags": ["Organizations", "Accounts"],
        "operationId": "createOrganizationInvitation",
        "summary": "Invite an email address to an organization as a member",
        "security": [{ "ServiceAuth": [], "BearerAuth": [] }],
        "parameters": [{ "name": "organizationID", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CreateInvitationRequest" } } } },
        "responses": {
          "201": { "description": "Invitation created or refreshed and its notification sent", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Invitation" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" },
